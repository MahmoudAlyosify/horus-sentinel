# ============================================================
# HORUS SENTINEL — Environment Template
# Copy to .env and fill in. NEVER commit the real .env file.
# ============================================================

# ---- Application ----
APP_ENV=development              # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---- PostgreSQL (jobs, RoE, audit, findings) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=horus_sentinel
POSTGRES_USER=horus
POSTGRES_PASSWORD=change_me_in_real_env

# Relational DB the app actually connects to. Leave unset for a zero-setup SQLite file;
# set it to Postgres for the full stack (the docker-compose api service sets this for you).
# DATABASE_URL=postgresql+psycopg://horus:change_me_in_real_env@localhost:5432/horus_sentinel

# ---- Neo4j (Intelligence Knowledge Graph) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_real_env

# ---- Redis (cache, rate budgets, task queue) ----
REDIS_URL=redis://localhost:6379/0

# ---- Job queue + workers (Phase 5.2) ----
QUEUE_BACKEND=memory         # memory (in-process, default) | redis (full stack, scalable workers)
WORKER_ENABLED=false         # true = run an in-process worker on API startup (single-node convenience)
# Standalone worker: `python -m workflows.worker`  (docker-compose runs a dedicated `worker` service)

# ---- ChromaDB (RAG vector store) ----
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ---- HORUS Brain — backend selection ----
# hybrid        = try Hugging Face online first, fall back to local Ollama (recommended)
# hf_serverless = HF Inference router (serverless) only
# hf_endpoint   = a dedicated HF Inference Endpoint URL only
# ollama        = self-hosted Ollama only (data sovereignty — nothing leaves the box)
BRAIN_BACKEND=hybrid

# Report / narrative language:  ar = Arabic (RTL, default) | en = English
REPORT_LANGUAGE=ar

# ---- Self-hosted model via Ollama ----
OLLAMA_ENDPOINT=http://localhost:11434
HORUS_MODEL_NAME=horus-osint

# ---- Hugging Face online model ----
# The token is normally entered on FIRST RUN (Command Center modal or `python -m core.setup_wizard`)
# and saved here automatically. You can also set it directly:
HF_TOKEN=
HF_MODEL_ID=mahmoudalyosify/Horus-OSINT
HF_ENDPOINT_URL=                 # only for BRAIN_BACKEND=hf_endpoint (dedicated endpoint)
HF_MAX_NEW_TOKENS=512

# ---- LLM provider selection (legacy label; kept for reference) ----
LLM_PROVIDER=horus-selfhosted    # horus-selfhosted | claude | openai
# Only needed if using a cloud provider as fallback:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ============================================================
# OSINT / Threat-Intel source API keys (all PASSIVE sources)
# Free tiers are fine for a portfolio/competition build.
# ============================================================
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
OTX_API_KEY=
ABUSEIPDB_API_KEY=
HIBP_API_KEY=

# ---- Knowledge / RAG / reporting paths ----
# Real GTD/GDELT corpus (falls back to data/geo_corpus.sample.json until provided):
GEO_CORPUS_PATH=data/geo_corpus.json
CHROMA_PERSIST_DIR=data/chroma
REPORT_OUTPUT_DIR=data/reports
RAG_TOP_K=4
RAG_BACKEND=keyword          # keyword (default, deterministic) | chroma (semantic, full stack)

# ---- Object store (immutable evidence) ----
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=horus-evidence
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_in_real_env
