# Copy to .env and adjust for your environment.

ARGUS_APP_ENV=development

# Postgres
ARGUS_DATABASE_URL=postgresql+asyncpg://argus:argus@localhost:5432/argus

# Redis (wired in from week 3)
ARGUS_REDIS_URL=redis://localhost:6379/0

# HMAC key for signing/verifying RoE records.
# MUST be a long random secret outside of local dev, and must be shared
# between whoever signs RoE records and the running API instance.
ARGUS_ROE_SIGNING_KEY=dev-only-insecure-signing-key-change-me
